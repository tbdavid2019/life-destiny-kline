    {"age": 46, "year": 2048, "daYun": "戊午", "ganZhi": "戊辰", "open": 90, "close": 80, "high": 90, "low": 75, "score": 80, "reason": "土重泄氣。從巔峯平穩落地，開始注重養生，放權給晚輩，安享成果。"},
    {"age": 47, "year": 2049, "daYun": "戊午", "ganZhi": "己巳", "open": 80, "close": 85, "high": 88, "low": 78, "score": 85, "reason": "巳午會火。依然強勁，家族興旺，子女有成，心情舒暢。"},
    {"age": 48, "year": 2050, "daYun": "丁巳", "ganZhi": "庚午", "open": 85, "close": 75, "high": 85, "low": 70, "score": 75, "reason": "進入丁巳大運，火勢依然強勁。流年庚午，火克金。財運雖好但花費也大，注意父親身體健康。"},
    {"age": 49, "year": 2051, "daYun": "丁巳", "ganZhi": "辛未", "open": 75, "close": 70, "high": 78, "low": 65, "score": 70, "reason": "丙辛合，巳未拱火。平穩安逸，家庭聚會增多，享受天倫之樂。"},
    {"age": 50, "year": 2052, "daYun": "丁巳", "ganZhi": "壬申", "open": 70, "close": 55, "high": 70, "low": 50, "score": 55, "reason": "巳申合水，壬水克身。年過半百，遇到歲運相剋。需防心血管突發疾病，減少外出，避免高風險投資。"},
    {"age": 51, "year": 2053, "daYun": "丁巳", "ganZhi": "癸酉", "open": 55, "close": 50, "high": 60, "low": 45, "score": 50, "reason": "巳酉合金。財黨殺。壓力來自外部環境變化或子女創業需求，量力而行，不可逞強。"},
    {"age": 52, "year": 2054, "daYun": "丁巳", "ganZhi": "甲戌", "open": 50, "close": 65, "high": 70, "low": 50, "score": 65, "reason": "甲木生火，戌土火庫。運勢回升，貴人相助，身體康復，心情轉好。"},
    {"age": 53, "year": 2055, "daYun": "丁巳", "ganZhi": "乙亥", "open": 65, "close": 60, "high": 65, "low": 55, "score": 60, "reason": "巳亥衝。馬星對沖。驛馬動，可能移民、搬家或長途旅行。動中由於火被水克，注意交通安全。"},
    {"age": 54, "year": 2056, "daYun": "丁巳", "ganZhi": "丙子", "open": 60, "close": 55, "high": 62, "low": 50, "score": 55, "reason": "日柱伏吟，水火激戰。家宅不安，配偶身體欠安，需多做善事化解。"},
    {"age": 55, "year": 2057, "daYun": "丁巳", "ganZhi": "丁丑", "open": 55, "close": 60, "high": 65, "low": 50, "score": 60, "reason": "巳醜拱金，丁火幫身。吉凶參半，財務上有新的規劃，適合傳承資產給下一代。"},
    {"age": 56, "year": 2058, "daYun": "丁巳", "ganZhi": "戊寅", "open": 60, "close": 80, "high": 85, "low": 60, "score": 80, "reason": "寅巳相刑生火。長生之地，老當益壯，精神矍鑠，可能在某個領域重新煥發第二春。"},
    {"age": 57, "year": 2059, "daYun": "丁巳", "ganZhi": "己卯", "open": 80, "close": 78, "high": 82, "low": 75, "score": 78, "reason": "木火相生。平穩順遂，受人愛戴，適合著書立說，總結人生經驗。"},
    {"age": 58, "year": 2060, "daYun": "丙辰", "ganZhi": "庚辰", "open": 78, "close": 60, "high": 78, "low": 55, "score": 60, "reason": "進入丙辰大運，火氣漸退，溼土悔火。庚辰流年，雙龍戲水。運勢下滑，應徹底退休，不問世事。"},
    {"age": 59, "year": 2061, "daYun": "丙辰", "ganZhi": "辛巳", "open": 60, "close": 65, "high": 70, "low": 58, "score": 65, "reason": "丙辛合，巳火幫身。雖大運一般，流年尚可。小病小災無大礙。"},
    {"age": 60, "year": 2062, "daYun": "丙辰", "ganZhi": "壬午", "open": 65, "close": 55, "high": 68, "low": 50, "score": 55, "reason": "壬水七殺剋日主，午火羊刃被衝。六十耳順之年，防心臟不適，情緒不宜波動。"},
    {"age": 61, "year": 2063, "daYun": "丙辰", "ganZhi": "癸未", "open": 55, "close": 50, "high": 58, "low": 48, "score": 50, "reason": "歲運並臨年柱。天剋地衝。健康坎坷，需注意脾胃與腎臟，保守治療爲主。"},
    {"age": 62, "year": 2064, "daYun": "丙辰", "ganZhi": "甲申", "open": 50, "close": 45, "high": 50, "low": 40, "score": 45, "reason": "申子辰三合水局。水大滅火。由於木透幹尚有生機，但需嚴防跌倒骨折。"},
    {"age": 63, "year": 2065, "daYun": "丙辰", "ganZhi": "乙酉", "open": 45, "close": 42, "high": 48, "low": 40, "score": 42, "reason": "辰酉合金。乙木受克。肝膽不適，視力下降，靜養爲主。"},
    {"age": 64, "year": 2066, "daYun": "丙辰", "ganZhi": "丙戌", "open": 42, "close": 55, "high": 60, "low": 42, "score": 55, "reason": "辰戌衝，火庫開。丙火助身。身體好轉，遇到名醫，狀態回升。"},
    {"age": 65, "year": 2067, "daYun": "丙辰", "ganZhi": "丁亥", "open": 55, "close": 50, "high": 55, "low": 48, "score": 50, "reason": "亥水沖剋。雖有丁火，杯水車薪。注意冬季保暖，防流感。"},
    {"age": 66, "year": 2068, "daYun": "丙辰", "ganZhi": "戊子", "open": 50, "close": 40, "high": 50, "low": 35, "score": 40, "reason": "申子辰水局成化。七殺攻身。大關口。意志力關鍵，需家人悉心照料。"},
    {"age": 67, "year": 2069, "daYun": "丙辰", "ganZhi": "己丑", "open": 40, "close": 38, "high": 42, "low": 35, "score": 38, "reason": "醜辰溼土晦火。元氣大傷，修養生息。"},
    {"age": 68, "year": 2070, "daYun": "乙卯", "ganZhi": "庚寅", "open": 38, "close": 60, "high": 65, "low": 38, "score": 60, "reason": "進入乙卯大運，真神得用！晚年行印運，長壽之徵兆。庚寅流年助勢，枯木逢春，身體奇蹟般好轉。"},
    {"age": 69, "year": 2071, "daYun": "乙卯", "ganZhi": "辛卯", "open": 60, "close": 65, "high": 68, "low": 58, "score": 65, "reason": "雙卯幫身。思維清晰，可能對宗教或哲學有深刻領悟，心態超然。"},
    {"age": 70, "year": 2072, "daYun": "乙卯", "ganZhi": "壬辰", "open": 65, "close": 55, "high": 65, "low": 50, "score": 55, "reason": "壬水生木，木生火。殺印相生。雖有病痛但無大礙，平安是福。"},
    {"age": 71, "year": 2073, "daYun": "乙卯", "ganZhi": "癸巳", "open": 55, "close": 60, "high": 65, "low": 52, "score": 60, "reason": "巳火祿地。精神不錯，老友相聚，心情開朗。"},
    {"age": 72, "year": 2074, "daYun": "乙卯", "ganZhi": "甲午", "open": 60, "close": 70, "high": 75, "low": 60, "score": 70, "reason": "木火通明。七十古來稀，身體硬朗，福澤子孫。"},
    {"age": 73, "year": 2075, "daYun": "乙卯", "ganZhi": "乙未", "open": 70, "close": 68, "high": 72, "low": 65, "score": 68, "reason": "亥卯未三合木局。印星強旺，受人尊崇，生活無憂。"},
    {"age": 74, "year": 2076, "daYun": "乙卯", "ganZhi": "丙申", "open": 68, "close": 50, "high": 68, "low": 45, "score": 50, "reason": "申金沖剋寅/卯。金木交戰。注意肝膽及肢體神經痛風，行動不便。"},
    {"age": 75, "year": 2077, "daYun": "乙卯", "ganZhi": "丁酉", "open": 50, "close": 45, "high": 50, "low": 40, "score": 45, "reason": "卯酉衝。衝提綱。健康滑坡，需防意外摔傷，居家需有人看護。"},
    {"age": 76, "year": 2078, "daYun": "乙卯", "ganZhi": "戊戌", "open": 45, "close": 50, "high": 55, "low": 45, "score": 50, "reason": "卯戌合火。運勢回穩，食神泄秀，胃口尚可。"},
    {"age": 77, "year": 2079, "daYun": "乙卯", "ganZhi": "己亥", "open": 50, "close": 48, "high": 52, "low": 45, "score": 48, "reason": "亥卯半合木。平平淡淡，修身養性。"},
    {"age": 78, "year": 2080, "daYun": "甲寅", "ganZhi": "庚子", "open": 48, "close": 40, "high": 48, "low": 35, "score": 40, "reason": "進入甲寅大運，依然是好運。但流年庚子，水大木漂。健康波動大，腎氣不足。"},
    {"age": 79, "year": 2081, "daYun": "甲寅", "ganZhi": "辛丑", "open": 40, "close": 35, "high": 42, "low": 30, "score": 35, "reason": "丙辛合，醜溼土。體力衰退，記憶力減退，需靜養。"},
    {"age": 80, "year": 2082, "daYun": "甲寅", "ganZhi": "壬寅", "open": 35, "close": 55, "high": 60, "low": 35, "score": 55, "reason": "雙寅到位。長生加持。八十整壽，子孫滿堂，迴光返照之象。"},
    {"age": 81, "year": 2083, "daYun": "甲寅", "ganZhi": "癸卯", "open": 55, "close": 58, "high": 60, "low": 52, "score": 58, "reason": "寅卯混雜。木氣過盛，需防肝火過旺導致的中風，總體安穩。"},
    {"age": 82, "year": 2084, "daYun": "甲寅", "ganZhi": "甲辰", "open": 58, "close": 55, "high": 60, "low": 50, "score": 55, "reason": "寅卯辰三會木方。木多火塞。心臟負荷大，不可勞累。"},
    {"age": 83, "year": 2085, "daYun": "甲寅", "ganZhi": "乙巳", "open": 55, "close": 60, "high": 65, "low": 55, "score": 60, "reason": "寅巳相刑生火。老來得福，雖有病痛但精神矍鑠。"},
    {"age": 84, "year": 2086, "daYun": "甲寅", "ganZhi": "丙午", "open": 60, "close": 65, "high": 70, "low": 58, "score": 65, "reason": "木火通明。本命年（丙火日元），火氣太旺，雖精神好但屬於虛火，注意保養。"},
    {"age": 85, "year": 2087, "daYun": "甲寅", "ganZhi": "丁未", "open": 65, "close": 55, "high": 65, "low": 50, "score": 55, "reason": "火土相生。元氣漸散，順其自然。"},
    {"age": 86, "year": 2088, "daYun": "甲寅", "ganZhi": "戊申", "open": 55, "close": 30, "high": 55, "low": 25, "score": 30, "reason": "寅申衝。沖剋大運流年。金木交戰，大限恐至。若過此關，需行大善積德。"},
    {"age": 87, "year": 2089, "daYun": "甲寅", "ganZhi": "己酉", "open": 30, "close": 25, "high": 35, "low": 20, "score": 25, "reason": "土金耗氣。生命之火微弱，一切隨緣。"},
    {"age": 88, "year": 2090, "daYun": "癸丑", "ganZhi": "庚戌", "open": 25, "close": 30, "high": 35, "low": 20, "score": 30, "reason": "進入癸丑大運。溼土晦火。庚戌拱火。迴光返照，安排後事。"},
    {"age": 89, "year": 2091, "daYun": "癸丑", "ganZhi": "辛亥", "open": 30, "close": 20, "high": 30, "low": 10, "score": 20, "reason": "亥子醜水局。官殺克身無制。天命已定，迴歸自然。"},
    {"age": 90, "year": 2092, "daYun": "癸丑", "ganZhi": "壬子", "open": 20, "close": 10, "high": 20, "low": 0, "score": 10, "reason": "水旺滅火。塵歸塵，土歸土。一生傳奇，至此落幕。"},
    {"age": 91, "year": 2093, "daYun": "癸丑", "ganZhi": "癸丑", "open": 10, "close": 10, "high": 10, "low": 0, "score": 10, "reason": "史書一頁。"},
    {"age": 92, "year": 2094, "daYun": "癸丑", "ganZhi": "甲寅", "open": 10, "close": 10, "high": 10, "low": 0, "score": 10, "reason": "後世評說。"},
    {"age": 93, "year": 2095, "daYun": "癸丑", "ganZhi": "乙卯", "open": 10, "close": 10, "high": 10, "low": 0, "score": 10, "reason": "家族祭祀。"},
    {"age": 94, "year": 2096, "daYun": "癸丑", "ganZhi": "丙辰", "open": 10, "close": 10, "high": 10, "low": 0, "score": 10, "reason": "香火延續。"},
    {"age": 95, "year": 2097, "daYun": "癸丑", "ganZhi": "丁巳", "open": 10, "close": 10, "high": 10, "low": 0, "score": 10, "reason": "遺澤後人。"},
    {"age": 96, "year": 2098, "daYun": "癸丑", "ganZhi": "戊午", "open": 10, "close": 10, "high": 10, "low": 0, "score": 10, "reason": "精神不朽。"},
